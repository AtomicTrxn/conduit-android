root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 140

# Jetpack Compose uses PascalCase for @Composable functions by convention.
# Suppress ktlint's function-naming rule for composable-annotated functions.
ktlint_function_naming_ignore_when_annotated_with = Composable
